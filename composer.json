{
    "name": "mohamed/ieee-zsb-backend-php",
    "authors": [
        {
            "name": "Mohamed Hagag",
            "email": "hagag0446@gmail.com"
        }
    ],
    "require": {
        "illuminate/collections": "^11.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "core\\": "core/",
            "http\\": "http/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
